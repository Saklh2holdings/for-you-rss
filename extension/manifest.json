{
  "manifest_version": 3,
  "name": "ForYou RSS Sync",
  "version": "1.2.0",
  "description": "Captures session cookies and live API endpoints from Twitter, YouTube, Reddit, and TikTok and syncs them to your ForYou RSS server.",
  "permissions": [
    "cookies",
    "storage",
    "webRequest",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*",
    "*://www.instagram.com/*",
    "*://www.tiktok.com/*",
    "*://www.youtube.com/*",
    "*://www.reddit.com/*",
    "http://localhost:*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.tiktok.com/*"],
      "js": ["content-tiktok-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["*://www.tiktok.com/*"],
      "js": ["content-tiktok.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content-youtube-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content-youtube.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ForYou RSS Sync"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
