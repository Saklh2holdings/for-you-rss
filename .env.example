# ---- Server ----
PORT=3000

# Public URL used inside RSS feed link tags.
# Change to your Railway / hosted URL for production.
PUBLIC_BASE_URL=http://localhost:3000

# ---- Optional: protect POST /credentials ----
# If set, all requests to POST /credentials must include:
#   Authorization: Bearer <ADMIN_API_KEY>
# Leave blank to skip auth (safe for local use only).
ADMIN_API_KEY=

# ---- Twitter / X ----
# The public guest bearer token. Only change if X rotates it.
# TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAANRILgAAAAAAnNwIzUejRCOuH5E6I8xnZz4puTs%3D1Zv7ttfk8LF81IUq16cHjhLTvJu4FA33AGWWjCpTnA

# Manual fallback queryId — only needed if you're not using the Chrome extension.
# Copy from DevTools Network > filter "HomeTimeline" > first path segment after /graphql/
# TWITTER_HOME_QUERY_ID=

# ---- Storage paths (optional overrides) ----
# COOKIES_DIR=./cookies
# OUTPUT_DIR=./output
